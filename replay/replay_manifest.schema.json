{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jsonwisdom.example/schemas/witness-replay-v2-7.schema.json",
  "title": "Witness Replay Manifest v2.7",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "framework",
    "authority",
    "repo",
    "base_commit",
    "environment",
    "inputs",
    "command",
    "state_root_algorithm",
    "expected_state_root",
    "halt_on_mismatch",
    "rule"
  ],
  "properties": {
    "framework": { "const": "WITNESS_REPLAY_V2_7" },
    "authority": { "const": false },
    "repo": { "type": "string", "minLength": 1 },
    "base_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "timezone", "locale", "container_image"],
      "properties": {
        "python": { "const": "3.12.4" },
        "timezone": { "const": "UTC" },
        "locale": { "const": "C.UTF-8" },
        "container_image": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "pattern": "^([0-9a-f]{64}|TO_BE_COMPUTED_BY_FIRST_WITNESS)$"
          }
        }
      }
    },
    "command": { "const": "python replay/verify_replay.py --manifest replay/replay_manifest.json" },
    "state_root_algorithm": { "const": "sha256(sorted(path + ':' + sha256(file)))" },
    "expected_state_root": {
      "type": "string",
      "pattern": "^([0-9a-f]{64}|TO_BE_COMPUTED_BY_FIRST_WITNESS)$"
    },
    "halt_on_mismatch": { "const": true },
    "rule": { "type": "string", "minLength": 1 }
  }
}
