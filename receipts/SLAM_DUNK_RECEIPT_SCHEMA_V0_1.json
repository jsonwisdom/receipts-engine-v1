{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SLAM_DUNK_RECEIPT_V0_1",
  "description": "Constitutional finality-class receipt definition governed by FINALITY_PROTOCOL_V0_1.",
  "type": "object",
  "required": [
    "receipt_schema_version",
    "receipt_type",
    "receipt_id",
    "previous_receipt_hash",
    "timestamp_utc",
    "event_hash",
    "finality_proof",
    "witness",
    "metadata"
  ],
  "properties": {
    "receipt_schema_version": {
      "type": "string",
      "const": "V0_1"
    },
    "receipt_type": {
      "type": "string",
      "const": "SLAM_DUNK"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "previous_receipt_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "finality_proof": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "witness": {
      "type": "object",
      "required": [
        "actor",
        "signature"
      ],
      "properties": {
        "actor": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
